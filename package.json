{
  "name": "paladar-asuncion",
  "version": "1.0.0",
  "description": "Buscador inteligente de platos en restaurantes de Asuncion y Gran Asuncion",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc && webpack --mode production",
    "build:dev": "tsc && webpack --mode development",
    "start": "node dist/server/index.js",
    "dev": "concurrently \"tsc -w\" \"webpack serve --mode development\" \"nodemon dist/server/index.js\"",
    "init-db": "node scripts/init-db.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite": "^4.2.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.19",
    "@types/node": "^20.8.6",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "concurrently": "^8.2.1",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "nodemon": "^3.0.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
